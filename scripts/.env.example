# Environment variables for startup script
# Copy this to scripts\.env and fill in your values

# Ngrok - get from https://dashboard.ngrok.com/get-started
NGROK_TOKEN=

# Vercel - get from https://vercel.com/settings/tokens
VERCEL_TOKEN=

# Vercel Project ID - get from your project settings
VERCEL_PROJECT_ID=

# Vercel Deploy Hook URL - create in Vercel project settings > Git > Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=